<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jimeng.persistence.mapper.SysEnvMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.jimeng.persistence.entity.SysEnv">
        <id column="id" property="id" />
        <result column="module_name" property="moduleName" />
        <result column="name" property="name" />
        <result column="property_name" property="propertyName" />
        <result column="property_value" property="propertyValue" />
        <result column="remark" property="remark" />
        <result column="deleted" property="deleted" />
        <result column="create_time" property="createTime" />
        <result column="create_user" property="createUser" />
        <result column="update_time" property="updateTime" />
        <result column="update_user" property="updateUser" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, module_name, name, property_name, property_value, remark,
        deleted, create_time, create_user, update_time, update_user
    </sql>

</mapper>
